{
  "name": "@t8/react-client-only",
  "version": "1.0.0",
  "description": "A lightweight React component and a hook to render content on the client and skip SSR",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { force: true, recursive: true });\"",
    "compile": "npx esbuild index.ts --bundle --outdir=dist --platform=neutral --external:react",
    "preversion": "npx npm-run-all clean shape compile",
    "shape": "npx codeshape --typecheck --emit-types"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t8js/react-client-only.git"
  },
  "keywords": [
    "react",
    "client only",
    "ssr"
  ],
  "author": "axtk",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8"
  },
  "devDependencies": {
    "@types/react": "^19.2.7"
  }
}
